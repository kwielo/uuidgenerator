{
    "name": "kwielo/uuidgenerator",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ramsey/uuid": "^4.7",
        "symfony/config": "^6.4",
        "symfony/dependency-injection": "^6.4",
        "symfony/framework-bundle": "^6.4",
        "symfony/http-foundation": "^6.4",
        "symfony/http-kernel": "^6.4",
        "symfony/routing": "^6.4",
        "symfony/runtime": "^6.4",
        "symfony/twig-bundle": "^6.4",
        "symfony/yaml": "^6.4",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "symfony/dotenv": "^6.4"
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/App"
        }
    },
    "authors": [
        {
            "name": "Krzysztof Wielogórski",
            "email": "contact@wielo.co"
        }
    ]
}
