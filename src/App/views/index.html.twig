<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{{ type|capitalize }} generator</title>
        <link rel="shortcut icon" href="/media/favicon.png" />
        <link rel="stylesheet" type="text/css" href="/media/app.css">
        <script>
            if (localStorage.getItem('uuidgen_theme') === 'light') {
                document.documentElement.setAttribute('data-theme', 'light');
            }
        </script>
    </head>
    <body>
        <div class="page">
            <nav class="toolbar">
                <div class="toolbar__left">
                    <h1 class="toolbar__title">
                        <a href="/">
                            <svg class="toolbar__logo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24" aria-hidden="true" focusable="false">
                                <line x1="4" y1="9" x2="20" y2="9"/>
                                <line x1="4" y1="15" x2="20" y2="15"/>
                                <line x1="10" y1="3" x2="8" y2="21"/>
                                <line x1="16" y1="3" x2="14" y2="21"/>
                            </svg>
                            uuidgen
                        </a>
                    </h1>
                </div>
                <div class="toolbar__right">
                    <button class="btn btn--icon toolbar__theme" title="Toggle theme" aria-label="Toggle dark/light mode">
                        <svg class="toolbar__theme-icon--light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                            <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
                            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                            <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
                            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                        </svg>
                        <svg class="toolbar__theme-icon--dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                        </svg>
                    </button>
                </div>
            </nav>

            <div class="intro">
                <h2>{{ type|capitalize }} generator</h2>
                <p>Generate {{ type }} UUIDs — pick a version and count, then copy.</p>
            </div>

            <div class="controls">
                <div class="controls__field">
                    <label for="type-input">Version</label>
                    <select id="type-input" class="type-input" aria-label="UUID type">
                        {% for uuid_type in uuid_types %}
                            <option value="{{ uuid_type }}" {% if uuid_type == type %}selected="selected"{% endif %}>{{ uuid_type }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="controls__field controls__range">
                    <label for="bulk-input">Count</label>
                    <div class="controls__range-row">
                        <input id="bulk-input" class="bulk-input" type="range" min="1" max="{{ constant('App\\Repository\\UuidRepository::MAX_BULK') }}" value="{{ bulk }}" aria-label="Number of UUIDs to generate">
                        <span class="bulk-value">{{ bulk }}</span>
                    </div>
                </div>
                <button type="button" class="btn btn--primary bulk-submit" aria-label="Generate UUIDs">Generate</button>
            </div>

            <div class="results">
                <div class="uuid-line">
                    <span class="uuid-index" aria-hidden="true">#0</span>
                    <input class="uuid-input" type="text" value="{{ nil }}" readonly aria-label="Nil UUID" />
                    <button type="button" class="uuid-copy" aria-label="Copy nil UUID to clipboard">
                        <svg class="icon-copy" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false"><path fill="none" stroke="currentColor" stroke-width="2" d="M9 9h10v10H9zM6 15H4V4h10v2"/></svg>
                        <svg class="icon-check" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false"><path fill="none" stroke="currentColor" stroke-width="2" d="M4 12l5 5L20 6"/></svg>
                    </button>
                </div>
                {% for uuid in uuids %}
                    <div class="uuid-line">
                        <span class="uuid-index" aria-hidden="true">#{{ loop.index }}</span>
                        <input class="uuid-input" type="text" value="{{ uuid }}" readonly aria-label="Generated UUID {{ loop.index }}" />
                        <button type="button" class="uuid-copy" aria-label="Copy UUID {{ loop.index }} to clipboard">
                            <svg class="icon-copy" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false"><path fill="none" stroke="currentColor" stroke-width="2" d="M9 9h10v10H9zM6 15H4V4h10v2"/></svg>
                            <svg class="icon-check" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false"><path fill="none" stroke="currentColor" stroke-width="2" d="M4 12l5 5L20 6"/></svg>
                        </button>
                    </div>
                {% endfor %}
                <p class="copy-feedback sr-only" role="status" aria-live="polite"></p>
            </div>

            <footer class="app-footer">
                <span>&copy; {{ "now"|date("Y") }} <a href="https://wielo.co" target="_blank" rel="noopener">wielo.co</a></span>
                <nav class="app-footer__links">
                    <a href="https://github.com/kwielo/uuidgenerator" target="_blank" rel="noopener">GitHub</a>
                </nav>
            </footer>
        </div>

        <div id="toast-container"></div>
        <script type="text/javascript" src="/media/app.js"></script>
        <!-- Matomo -->
        <script type="text/javascript">
          var _paq = _paq || [];
          /* tracker methods like "setCustomDimension" should be called before "trackPageView" */
          _paq.push(['trackPageView']);
          _paq.push(['enableLinkTracking']);
          (function() {
            var u="//stats25.mydevil.net/";
            _paq.push(['setTrackerUrl', u+'piwik.php']);
            _paq.push(['setSiteId', '32']);
            var d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];
            g.type='text/javascript'; g.async=true; g.defer=true; g.src=u+'piwik.js'; s.parentNode.insertBefore(g,s);
          })();
        </script>
        <!-- End Matomo Code -->
    </body>
</html>
